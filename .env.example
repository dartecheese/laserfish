# Copy to .env and fill in your values

# Hyperliquid — EVM wallet (used for signing orders)
HL_PRIVATE_KEY=0x...
HL_WALLET_ADDRESS=0x...

# dYdX v4 — Cosmos mnemonic
DYDX_MNEMONIC=word1 word2 ... word24

# Drift — Solana private key (base58)
DRIFT_PRIVATE_KEY=...

# Optional: Binance API for enhanced rate limits on data fetch
BINANCE_API_KEY=
BINANCE_SECRET=

# Trading config
TRADE_SYMBOLS=BTC,ETH,SOL
TRADE_EXCHANGE=hyperliquid
LEVERAGE=1
MAX_POSITION_PCT=0.25
